<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Titre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Planification d'un Rendez-Vous"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:paddingBottom="24dp"
            android:paddingTop="12dp"/>

        <!-- Titre du RDV -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Titre du rendez-vous"
            android:textSize="14sp"
            android:textColor="#424242"
            android:paddingBottom="4dp"/>
        <EditText
            android:id="@+id/etTitreRdv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Titre du rendez-vous"
            android:inputType="text"
            android:background="@drawable/edittext_bg"
            android:padding="12dp"
            android:layout_marginBottom="20dp"/>

        <!-- Date du RDV -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date du rendez-vous"
            android:textSize="14sp"
            android:textColor="#424242"
            android:paddingBottom="4dp"/>
        <DatePicker
            android:id="@+id/datePickerRdv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:datePickerMode="spinner"
            android:calendarViewShown="false"
            android:layout_marginBottom="20dp"/>

        <!-- Heure du RDV -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Heure du rendez-vous"
            android:textSize="14sp"
            android:textColor="#424242"
            android:paddingBottom="4dp"/>
        <TimePicker
            android:id="@+id/timePickerRdv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:timePickerMode="spinner"
            android:layout_marginBottom="20dp"/>

        <!-- Type de RDV -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type de rendez-vous"
            android:textSize="14sp"
            android:textColor="#424242"
            android:paddingBottom="4dp"/>
        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edittext_bg"
            android:padding="8dp"
            android:layout_marginBottom="24dp"/>

        <!-- Bouton Valider -->
        <Button
            android:id="@+id/btnValider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Valider"
            android:backgroundTint="#1A237E"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:padding="14dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
